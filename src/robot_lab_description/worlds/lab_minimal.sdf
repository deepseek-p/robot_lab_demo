<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="robot_lab_minimal">
    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.92 0.94 0.96 1</background>
    </scene>

    <light name="lab_key_light" type="directional">
      <pose>0 0 4 0.5 0.2 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.2 -1</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>5 5</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>5 5</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.55 0.58 0.60 1</ambient>
            <diffuse>0.55 0.58 0.60 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="lab_workbench">
      <static>true</static>
      <pose>0.75 0 0.78 0 0 0</pose>
      <link name="top">
        <collision name="collision">
          <geometry>
            <box>
              <size>1.0 0.7 0.06</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
