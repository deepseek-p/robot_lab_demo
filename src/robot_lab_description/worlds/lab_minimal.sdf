              <size>1.0 0.7 0.06</size>
            </box>
          </geometry>
          <material>
            <ambient>0.42 0.46 0.48 1</ambient>
            <diffuse>0.42 0.46 0.48 1</diffuse>
          </material>
        </visual>
      </link>
      <link name="left_front_leg">
        <pose>0.43 0.28 -0.39 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.05 0.05 0.78</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.05 0.05 0.78</size>
            </box>
          </geometry>
        </visual>
      </link>
      <link name="right_front_leg">
        <pose>0.43 -0.28 -0.39 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.05 0.05 0.78</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.05 0.05 0.78</size>
            </box>
          </geometry>
        </visual>
      </link>
      <link name="left_rear_leg">
        <pose>-0.43 0.28 -0.39 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.05 0.05 0.78</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.05 0.05 0.78</size>
            </box>
          </geometry>
        </visual>
      </link>
      <link name="right_rear_leg">
        <pose>-0.43 -0.28 -0.39 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.05 0.05 0.78</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.05 0.05 0.78</size>
            </box>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="sample_block">
      <static>false</static>
      <pose>0.58 0.18 0.84 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.00005</ixx>
            <iyy>0.00005</iyy>
            <izz>0.00005</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.07 0.07 0.07</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.07 0.07 0.07</size>
            </box>
          </geometry>
          <material>
            <ambient>0.0 0.45 0.85 1</ambient>
            <diffuse>0.0 0.45 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="target_pad">
      <static>true</static>
      <pose>0.58 -0.18 0.815 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.08</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.05 0.7 0.25 1</ambient>
            <diffuse>0.05 0.7 0.25 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Manipulable red vial: second grasp target for multi-task runs. -->
    <model name="sample_vial_red">
      <static>false</static>
      <pose>0.62 0.30 0.865 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.00005</ixx>
            <iyy>0.00005</iyy>
            <izz>0.00001</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.018</radius>
              <length>0.10</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.018</radius>
              <length>0.10</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.85 0.12 0.12 1</ambient>
            <diffuse>0.85 0.12 0.12 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Sample tray: secondary place target on the bench. -->
    <model name="sample_tray">
      <static>true</static>
      <pose>0.45 -0.30 0.8225 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.22 0.16 0.025</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
